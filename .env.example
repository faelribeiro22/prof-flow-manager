# ==========================================
# ProfFlow Manager - Environment Variables
# ==========================================
#
# 📋 Instruções de Setup:
# 1. Copie este arquivo: cp .env.example .env.local
# 2. Preencha os valores abaixo com suas credenciais
# 3. NUNCA commit o arquivo .env.local no git!
#
# 🔗 Links Úteis:
# - Supabase Dashboard: https://app.supabase.com/
# - Docs Supabase: https://supabase.com/docs
# - Projeto README: README.md
#
# ==========================================

# ------------------------------------------
# 🔑 Supabase Configuration (OBRIGATÓRIO)
# ------------------------------------------
#
# Como obter suas credenciais:
# 1. Acesse: https://app.supabase.com/
# 2. Selecione seu projeto
# 3. Vá em: Settings → API
# 4. Copie "Project URL" e "anon/public key"
#
# VITE_SUPABASE_URL: URL do seu projeto Supabase
# VITE_SUPABASE_ANON_KEY: Chave pública (anon key)

VITE_SUPABASE_URL=https://seu-projeto-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.sua-chave-aqui

# ------------------------------------------
# 🎨 Application Settings (OPCIONAL)
# ------------------------------------------
#
# Configurações gerais da aplicação
# Deixe comentado para usar valores padrão

# VITE_APP_NAME=AgendaPro
# VITE_APP_URL=http://localhost:8080

# ------------------------------------------
# 📱 WhatsApp Business API (OPCIONAL)
# ------------------------------------------
#
# ⚠️  IMPORTANTE: Não usar essas variáveis no frontend!
# Elas são apenas para referência. Configure via Supabase Secrets.
#
# Para configurar no Supabase:
# 1. Acesse: Dashboard → Edge Functions → Secrets
# 2. Adicione as secrets abaixo
#
# Como obter:
# - WhatsApp Business: https://developers.facebook.com/apps
# - Evolution API: https://doc.evolution-api.com/
#
# Opção 1: WhatsApp Business API (Oficial)
# WHATSAPP_API_KEY=EAAxxxxxxxxxxxxx
# WHATSAPP_PHONE_NUMBER_ID=123456789
# WHATSAPP_BUSINESS_ACCOUNT_ID=987654321
# WHATSAPP_WEBHOOK_VERIFY_TOKEN=seu-token-secreto
#
# Opção 2: Evolution API (Open Source)
# EVOLUTION_API_URL=https://sua-evolution-api.com
# EVOLUTION_API_KEY=sua-chave-da-evolution
# EVOLUTION_INSTANCE_NAME=seu-nome-da-instancia

# ------------------------------------------
# 🔧 Feature Flags (OPCIONAL)
# ------------------------------------------
#
# Habilitar/desabilitar features em desenvolvimento
# Valores aceitos: true ou false
# Deixe comentado para desabilitar

# VITE_ENABLE_WHATSAPP=false
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG=false
# VITE_ENABLE_MOCK_DATA=false

# ------------------------------------------
# 📊 Third-Party Services (OPCIONAL)
# ------------------------------------------
#
# Integrações com serviços de terceiros
# Deixe comentado se não for usar

# Google Analytics
# VITE_GA_TRACKING_ID=G-XXXXXXXXXX
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Sentry (Error Tracking)
# VITE_SENTRY_DSN=https://xxxxx@sentry.io/xxxxx
# VITE_SENTRY_ENVIRONMENT=development

# PostHog (Product Analytics)
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://app.posthog.com

# Vercel Analytics
# VITE_VERCEL_ANALYTICS_ID=xxxxxxxxxx

# ------------------------------------------
# 🧪 Development Only (DEV)
# ------------------------------------------
#
# ⚠️  NÃO usar em produção!
# Configurações apenas para desenvolvimento local

# Mock API (usar dados mockados em vez de Supabase)
# VITE_MOCK_API=false

# Log Level (error, warn, info, debug)
# VITE_LOG_LEVEL=info

# Desabilitar strict mode (não recomendado)
# VITE_DISABLE_STRICT_MODE=false

# ------------------------------------------
# 🚀 Production (PROD)
# ------------------------------------------
#
# Variáveis específicas para produção
# Configure na plataforma de deploy (Vercel, Netlify, etc)

# NODE_ENV=production
# VITE_API_URL=https://sua-api.com

# ==========================================
# ⚠️  SEGURANÇA - LEIA COM ATENÇÃO
# ==========================================
#
# ✅ FAZER:
# - Usar .env.local para desenvolvimento
# - Usar secrets da plataforma para produção
# - Revogar chaves comprometidas imediatamente
# - Usar chaves diferentes para dev/staging/prod
# - Manter backup seguro das chaves
#
# ❌ NÃO FAZER:
# - Commitar .env.local no git
# - Compartilhar chaves em público
# - Usar mesma chave em dev e prod
# - Expor chaves no código frontend
# - Deixar chaves hardcoded
#
# 🔍 Verificar se .env.local está gitignored:
# git status --ignored | grep .env.local
#
# 🔍 Verificar se há variáveis expostas:
# grep -r "SUPABASE" src/
#
# 📖 Docs de Segurança:
# https://supabase.com/docs/guides/api/api-keys
# https://vitejs.dev/guide/env-and-mode.html
#
# ==========================================

# ==========================================
# 📝 Notas Adicionais
# ==========================================
#
# - Variáveis com prefixo VITE_ são expostas no frontend
# - Variáveis sem prefixo são apenas para build/servidor
# - Reinicie o dev server após alterar variáveis
# - Use process.env no Node, import.meta.env no Vite
#
# Exemplo de uso no código:
# const supabaseUrl = import.meta.env.VITE_SUPABASE_URL;
#
# ==========================================
